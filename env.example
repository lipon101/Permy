# ---- Permy environment ----
# Copy to .env and fill in. Never commit real secrets.

# API
PERMY_ENV=local                      # local | staging | prod
PERMY_LOG_LEVEL=INFO
PERMY_HOST=0.0.0.0
PERMY_PORT=8000
PERMY_BASE_URL=http://localhost:8000

# Auth — comma-separated valid API keys. In prod these are RapidAPI-forwarded keys.
PERMY_API_KEYS=dev-key-1,dev-key-2
PERMY_ADMIN_KEYS=admin-key-1
# HMAC secret used to sign webhook deliveries
PERMY_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Postgres + PostGIS
DATABASE_URL=postgresql+asyncpg://permy:permy@localhost:5432/permy
PG_SSLMODE=prefer

# Redis (rate-limit + queue)
REDIS_URL=redis://localhost:6379/0

# Upstream open-data — no auth required for Socrata public datasets.
# Optional Socrata app token raises rate limits (anonymous ~1000/hr).
SOCRATA_APP_TOKEN=

# Geocoding — Census is free and requires no key; Smarty/Mapbox for rooftop on paid tiers.
GEOCODER_PROVIDER=census            # census | smarty | mapbox
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=
MAPBOX_API_TOKEN=

# Rate limits (per API key, per minute). Tiers can override in code.
PERMY_RATE_LIMIT_FREE=60
PERMY_RATE_LIMIT_PAID=600

# Sample mode (no-key playground) — the RapidAPI conversion funnel.
# Capped at PERMY_SAMPLE_MAX_PER_RESPONSE records (default 10) and
# PERMY_SAMPLE_DAILY_LIMIT requests/day per IP (default 30).
PERMY_SAMPLE_MAX_PER_RESPONSE=10
PERMY_SAMPLE_DAILY_LIMIT=30

# Toggles
PERMY_ENABLE_WEBHOOKS=true
PERMY_ENABLE_MCP=true

# MCP server — when hosting the MCP server separately from the API, point it at
# the deployed REST API. If unset, the MCP server runs in-process (same data).
# PERMY_API_URL=https://permy.onrender.com
# PERMY_API_KEY=your-direct-site-key
